ing.","operational_pattern":"Treat repeated asks as P0 documentation/decision work; respond within hours with frameworks not acknowledgments.","organizational_archetype":"Product leadership team in strategy reviews","hidden_assumptions":["Repeats may be forgetfulness not urgency","Not all repeats are strategic"],"pressure_scenarios":["Quarterly strategy cycles","Exec frustration thresholds"],"failure_modes":["Ignoring repeated cues until blowup","Superficial answers to deep questions"],"contradictions":["Fast response culture vs thoughtful depth"],"behavioral_signals":["Exec frustration on fourth repeat","Hour-turnaround loom frameworks"],"emotional_political_dynamics":["Exec exasperation","IC defensiveness"],"operational_adaptations":["Track exec question recurrence","Rapid framework responses"],"ai_era_implications":["AI can flag repeated themes in meeting notes"]},{"pattern_name":"Ask for more time when needed","source_episode":"The art of influence: The single most important skill that AI can't replace | Jessica Fain (Webflow, ex-Slack)","source_guest":"Jessica Fain","source_quote_or_context":"People afraid to ask for more exec time miss critical insight\u2014counterpoint to busy calendar reality.","category":"Influence","core_belief":"Insufficient time guarantees failed influence; asking for time is professional not annoying.","operational_pattern":"Request dedicated working sessions for complex bets; don't cram strategic pitches into leftover slots.","organizational_archetype":"PM influencing busy executives","hidden_assumptions":["Execs may refuse","Asking too often burns capital"],"pressure_scenarios":["Launch deadlines","Board prep weeks"],"failure_modes":["Under-prepared fast pitches","Over-scheduling exec time"],"contradictions":["Ask for time vs respect busy calendar"],"behavioral_signals":["Explicit time extension requests","Working sessions vs status updates"],"emotional_political_dynamics":["Fear of being 'too much'"],"operational_adaptations":["Pre-b