# Copy to .env and set your key. Never commit .env.
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
# Set to 1 for instant fallback responses (no OpenAI call)
REALITY_CHECK_SKIP_LLM=0
# Hard cap on wait time (seconds); over this → corpus fallback
OPENAI_TIMEOUT_SECONDS=28
OPENAI_MAX_TOKENS=2200
# 1 = slower structured schema; 0 = faster json_object (default)
OPENAI_USE_JSON_SCHEMA=0

# --- Production / Replit (set REALITY_CHECK_ENV=production on deploy) ---
REALITY_CHECK_ENV=development
# Comma-separated, e.g. https://your-app.replit.app (leave empty for same-origin only)
REALITY_CHECK_CORS_ORIGINS=
# 1 = show /docs (default off when REALITY_CHECK_ENV=production)
# REALITY_CHECK_ENABLE_DOCS=0
# Optional: block scripted abuse; browser UI does not send this header
# REALITY_CHECK_STRESS_TEST_API_KEY=
REALITY_CHECK_RATE_LIMIT_STRESS_TEST=6
REALITY_CHECK_RATE_LIMIT_PREVIEW=20
REALITY_CHECK_RATE_LIMIT_FEEDBACK=10
REALITY_CHECK_CUSTOM_PHILOSOPHY_MAX_LENGTH=500
REALITY_CHECK_FEEDBACK_ENABLED=1
