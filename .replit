run = "uvicorn reality_check.api.main:app --host 0.0.0.0 --port $PORT"
modules = ["python-3.11"]
hidden = [".venv", "__pycache__", ".pytest_cache"]

[deployment]
run = ["sh", "-c", "uvicorn reality_check.api.main:app --host 0.0.0.0 --port $PORT"]
deploymentTarget = "cloudrun"

[env]
REALITY_CHECK_ENV = "production"

[nix]
packages = ["libxcrypt"]
channel = "stable-25_05"
